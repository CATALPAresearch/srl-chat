{
  "name": "moodle-mod_openchat",
  "description": "mod_openchat is a ready to use Moodle activity plugin that enables users to chat with an open-source large language model including document chat based on retrieval augmented generation.",
  "version": "1.0.0",
  "author": "Niels Seidel <niels.seidel@fernuni-hagen.de",
  "license": "GPL-3.0-only",
  "private": true,
  "scripts": {
    "dev": "cross-env webpack --mode development --progress --hide-modules",
    "watch": "cross-env webpack --mode development --watch --hide-modules",
    "watch-hot": "cross-env webpack-dev-server --mode development --hot --inline --progress",
    "build": "cross-env NODE_OPTIONS=--openssl-legacy-provider webpack --mode production --progress --hide-modules",
    "tag-latest": "git tag -d latest && git push --delete github latest && git tag latest && git push github latest",
    "sniffer": "phpcbf --standard=moodle ../* && phpcs --standard=moodle ../*",
    "nodemon": "nodemon"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^6.7.2",
    "@fortawesome/free-solid-svg-icons": "^6.7.2",
    "@fortawesome/vue-fontawesome": "^2.0.10",
    "@types/store": "^2.0.2",
    "axios": "^1.8.1",
    "bootstrap-vue": "^2.23.1",
    "chart.js": "^2.9.4",
    "jsonpath": "^1.1.1",
    "jsonpath-plus": "^7.2.0",
    "nodemon": "^2.0.13",
    "vue": "^2.6.10",
    "vue-multiselect": "^2.1.9",
    "vue-router": "^3.6.5",
    "vue-showdown": "^2.4.1",
    "vuex": "^3.6.2"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not ie <= 8"
  ],
  "devDependencies": {
    "@babel/core": "^7.4.3",
    "@babel/plugin-syntax-dynamic-import": "^7.2.0",
    "@babel/preset-env": "^7.4.3",
    "babel-loader": "^8.0.5",
    "cross-env": "^5.2.0",
    "css-loader": "^2.1.1",
    "file-loader": "^3.0.1",
    "filemanager-webpack-plugin": "^3.0.0",
    "terser-webpack-plugin": "1.4.5",
    "ts-loader": "^8.2.0",
    "ts-node": "^10.9.1",
    "typescript": "4.6.4",
    "vue-loader": "^15.7.0",
    "vue-template-compiler": "^2.6.10",
    "webpack": "^4.30.0",
    "webpack-cli": "^3.3.0",
    "webpack-dev-server": "^3.3.1"
  }
}

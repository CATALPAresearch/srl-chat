# =======================================================================
#  SRL Chat – environment configuration
#  ONE file for both local development and Docker Compose.
#
#  LOCAL DEVELOPMENT  →  python / flask run
#    Use the "local" values below.
#
#  DOCKER COMPOSE     →  docker compose up
#    Change PG_HOST to "postgresql" and BASE_URL to your LLM endpoint.
# =======================================================================

# ── LLM backend ─────────────────────────────────────────────────────────
# Local Ollama (local dev):
BASE_URL=http://localhost:11434/
# Remote / Docker Ollama:
# BASE_URL=https://your-ollama-host/api/

API_KEY=
MODEL=phi3:latest

# ── Database ─────────────────────────────────────────────────────────────
# Local dev:
PG_HOST=localhost
# Docker (change to the service name in docker-compose.yml):
# PG_HOST=postgresql
PG_USER=postgres
PG_PORT=5432
PG_PASSWORD=postgres
PG_DB=srl_chat

# ── Application security ─────────────────────────────────────────────────
SECRET_KEY=change-me-in-production

# ── Interview / agent behaviour ──────────────────────────────────────────
# JSON file in config/interview/ (without .json extension)
INTERVIEW_PROTOCOL=interview_default

# Set to true to skip LLM calls (useful for UI development)
DISABLE_LLM=false

# ── RAG-based strategy detection ─────────────────────────────────────────
# Set to true to use pgvector embedding similarity instead of LLM CoT
USE_RAG_STRATEGY=false
RAG_EMBEDDING_MODEL=nomic-embed-text

# ── Embeddings (optional) ────────────────────────────────────────────────
EMBEDDING_URL=
EMBEDDING_MODEL=
EMBEDDING_TOKEN=

# ── Discord bot (optional) ───────────────────────────────────────────────
BOT_TOKEN=
DISCORD_SERVER_ID=
API_URL=http://api:5000
